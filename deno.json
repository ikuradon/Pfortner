{
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/log": "jsr:@std/log@0.224.14",
    "@std/path": "jsr:@std/path@^1.1.5",
    "@std/yaml": "jsr:@std/yaml@^1.1.1",
    "@nostr/tools": "jsr:@nostr/tools@2.23.6",
    "@nostr/tools/relay": "jsr:@nostr/tools@2.23.6/relay",
    "ajv": "npm:ajv@^8.20.0",
    "esbuild": "npm:esbuild@^0.28.1",
    "maxmind": "npm:maxmind@^5.0.6",
    "redis": "npm:redis@^6.0.0",
    "@fresh/core": "jsr:@fresh/core@^2.3.3",
    "@fresh/core/internal": "jsr:@fresh/core@^2.3.3/internal",
    "@fresh/core/runtime": "jsr:@fresh/core@^2.3.3/runtime",
    "preact": "npm:preact@^10.29.2",
    "preact/hooks": "npm:preact@^10.29.2/hooks",
    "preact/jsx-runtime": "npm:preact@^10.29.2/jsx-runtime",
    "preact-render-to-string": "npm:preact-render-to-string@^6.7.0",
    "$admin/": "./src/admin/"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "fmt": {
    "include": [
      "."
    ],
    "indentWidth": 2,
    "lineWidth": 120,
    "proseWrap": "preserve",
    "semiColons": true,
    "singleQuote": true,
    "useTabs": false
  },
  "lint": {
    "include": [
      "."
    ],
    "exclude": [
      "src/admin/ui/static/"
    ],
    "rules": {
      "exclude": [
        "no-explicit-any"
      ],
      "tags": [
        "recommended"
      ]
    }
  },
  "tasks": {
    "dev": "deno run --unstable-net --unstable-kv --allow-env --allow-net --allow-read --allow-write --watch src/server/main.ts",
    "dev:admin": "deno task dev",
    "serve": "deno run --unstable-net --unstable-kv --allow-env --allow-net --allow-read --allow-write src/server/main.ts",
    "build:admin-assets": "deno run --allow-env --allow-read --allow-write --allow-run scripts/build_admin_islands.ts",
    "build:admin-islands": "deno task build:admin-assets",
    "test": "deno test --allow-env --allow-net --allow-read --allow-write --unstable-net --unstable-kv src/",
    "bench": "deno run --allow-env --allow-net --allow-read --allow-write --unstable-net scripts/bench.ts bench.scenario.yaml"
  }
}
