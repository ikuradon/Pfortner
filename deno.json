{
  "imports": {
    "@std/yaml": "jsr:@std/yaml@1.0.5",
    "ajv": "npm:ajv@8.17.1"
  },
  "fmt": {
    "include": [
      "."
    ],
    "indentWidth": 2,
    "lineWidth": 120,
    "proseWrap": "preserve",
    "semiColons": true,
    "singleQuote": true,
    "useTabs": false
  },
  "lint": {
    "include": [
      "."
    ],
    "rules": {
      "exclude": [
        "no-explicit-any"
      ],
      "tags": [
        "recommended"
      ]
    }
  },
  "tasks": {
    "dev": "deno run --unstable-net --allow-env --allow-net --allow-read --watch scripts/serve.ts",
    "serve": "deno run --unstable-net --allow-env --allow-net --allow-read scripts/serve.ts",
    "serve:config": "deno run --unstable-net --allow-env --allow-net --allow-read scripts/serve.ts pfortner.yaml",
    "test": "deno test --allow-env --allow-net --unstable-net src/"
  }
}
