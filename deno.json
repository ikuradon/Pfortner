{
  "imports": {
    "@std/assert": "jsr:@std/assert@1.0.18",
    "@std/yaml": "jsr:@std/yaml@1.0.5",
    "@std/path": "jsr:@std/path@1.1.4",
    "ajv": "npm:ajv@8.17.1",
    "maxmind": "npm:maxmind@4.3.21",
    "redis": "npm:redis@4.7.0",
    "@fresh/core": "jsr:@fresh/core@^2.2.0",
    "preact": "npm:preact@^10.25.0",
    "preact/": "npm:preact@^10.25.0/",
    "preact/jsx-runtime": "npm:preact@^10.25.0/jsx-runtime",
    "@preact/signals": "npm:@preact/signals@^2.0.0",
    "preact-render-to-string": "npm:preact-render-to-string@^6.5.0",
    "$admin/": "./src/admin/"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "fmt": {
    "include": [
      "."
    ],
    "indentWidth": 2,
    "lineWidth": 120,
    "proseWrap": "preserve",
    "semiColons": true,
    "singleQuote": true,
    "useTabs": false
  },
  "lint": {
    "include": [
      "."
    ],
    "exclude": [
      "admin/static/"
    ],
    "rules": {
      "exclude": [
        "no-explicit-any"
      ],
      "tags": [
        "recommended"
      ]
    }
  },
  "tasks": {
    "dev": "deno run --unstable-net --allow-env --allow-net --allow-read --watch scripts/serve.ts",
    "dev:admin": "deno task dev",
    "serve": "deno run --unstable-net --allow-env --allow-net --allow-read scripts/serve.ts",
    "serve:config": "deno run --unstable-net --allow-env --allow-net --allow-read --allow-write=pfortner.yaml,pfortner.yaml.workbench.json scripts/serve.ts pfortner.yaml",
    "test": "deno test --allow-env --allow-net --allow-read --allow-write --unstable-net --unstable-kv src/",
    "bench": "deno run --allow-env --allow-net --allow-read --allow-write --unstable-net scripts/bench.ts bench.scenario.yaml"
  }
}
